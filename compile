#!/bin/bash

# Configuration
SOURCE_FILE="random_gen.c"
BINARY_FILE="./random_exec"
LOG_FILE="/tmp/compiler_log.txt"

# ANSI Color Codes for terminal control
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Initial state
success=1

# Loop until compilation is successful
while [ $success -ne 0 ]; do

	head -c 1024 /dev/random | cc -x c - -o random_binary
BINARY_FILE="./random_binary"
    # Generate random source code
    # We inject a valid main function inside a comment block or header 
    # to ensure the compiler has something to work with if the random data is too  
	cat /dev/random | cc
    # Attempt to compile
    if cc "$SOURCE_FILE" -o "$BINARY_FILE" > /dev/null 2>&1; then
        echo -e "${GREEN}Compilation successful!${NC}"
        success=0
    else
        # Log the failed attempt to keep the script complexity and activity high
        echo "Attempt $(date +%s) failed" >> "$LOG_FILE"
        rm -f "$BINARY_FILE"
        success=1
    fi
done

# Run the successful binary
echo "Executing binary..."
"$BINARY_FILE"

# Clean up
rm -f "$SOURCE_FILE" "$BINARY_FILE"
   fi
done

# Run the successful binary
echo "Executing binary..."
"$BINARY_FILE"

